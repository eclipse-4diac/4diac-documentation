<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

<xs:include schemaLocation="subappnetwork.xsd"/>

<xs:element name="ResourceType">
  <xs:complexType>
    <xs:complexContent>
      <xs:extension base="LibraryElement">
        <xs:sequence>
          <xs:element name="FBTypeName"    type="FBTypeName"    minOccurs="0" maxOccurs="unbounded"/>
          <xs:element ref="VarDeclaration" minOccurs="0"        maxOccurs="unbounded"/>
          <xs:element name="SubAppNetwork" type="SubAppNetwork" minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
      </xs:extension>
    </xs:complexContent>
  </xs:complexType>
</xs:element>

<xs:complexType name="FBTypeName">
  <xs:attribute name="Name" type="xs:string" use="required"/>
</xs:complexType>

</xs:schema>